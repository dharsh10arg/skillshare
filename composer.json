{
  "name": "skillsphere/backend",
  "description": "SkillSphere Laravel 12 style REST API",
  "type": "project",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "app/Models/CoreModels.php"
    ]
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "policy": {
      "advisories": {
        "block": false
      }
    }
  }
}
